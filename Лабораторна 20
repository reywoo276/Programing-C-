#include <iostream>
using namespace std;

class Square
{
private:
    double side;
    double area;

public:
    Square(double side);

    void set_side(double side)
    {
        if (side < 0)
            return;

        this->side = side;
        this->area = side * side;
    }

    double get_side() const
    {
        return side;
    }

    double get_area() const
    {
        return area;
    }

    void print()
    {
        cout << "Square: side=" << side << " area=" << area << endl;
    }
};

Square::Square(double side)
{
    set_side(side);
}

int main()
{
    Square s(4);

    s.print();

    s.set_side(2.0);
    s.print();

    s.set_side(-33.0);
    s.print();

    return 0;
}

