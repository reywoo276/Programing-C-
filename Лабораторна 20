#include <iostream>
using namespace std;


class AdHocSquare
{
public:
    AdHocSquare(double side)
    {
        this->side = side;
    }

    void set_side(double side)
    {
        this->side = side;
    }

    double get_area()
    {
        return side * side;
    }

private:
    double side;
};


class LazySquare
{
public:
    LazySquare(double side)
    {
        this->side = side;
        this->area = side * side;
        this->side_changed = false;
    }

    void set_side(double side)
    {
        this->side = side;
        this->side_changed = true;
    }

    bool changed()
    {
        return side_changed;
    }

    double get_area()
    {
        if (side_changed)
        {
            area = side * side;
            side_changed = false;
        }

        return area;
    }

private:
    double side;
    double area;
    bool side_changed;
};

int main()
{
    cout << "=== AdHocSquare ===" << endl;
    AdHocSquare a(4);
    cout << "Area: " << a.get_area() << endl;

    a.set_side(6);
    cout << "New Area: " << a.get_area() << endl;

    cout << "\n=== LazySquare ===" << endl;
    LazySquare b(4);
    cout << "Area: " << b.get_area() << endl;

    b.set_side(6);

    if (b.changed())
    {
        cout << "Side was changed!" << endl;
    }

    cout << "New Area: " << b.get_area() << endl;

    return 0;
}
