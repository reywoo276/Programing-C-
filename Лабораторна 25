#include <iostream>

class Tree {
public:
    virtual void draw() const = 0;   
    virtual ~Tree() {}
};

class Tree1 : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 1:" << std::endl;
        std::cout << " /\\" << std::endl;
        std::cout << "//\\\\" << std::endl;
    }
};

class Tree2 : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 2:" << std::endl;
        std::cout << " /\\" << std::endl;
        std::cout << "/**\\" << std::endl;
    }
};

class Tree3 : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 3:" << std::endl;
        std::cout << " /\\" << std::endl;
        std::cout << "/++\\" << std::endl;
    }
};

int main() {
    Tree* trees[3] = { new Tree1(), new Tree2(), new Tree3() };

    for (int i = 0; i < 3; i++) {
        trees[i]->draw();
        std::cout << std::endl;
    }
    
    for (int i = 0; i < 3; i++) {
        delete trees[i];
    }

    return 0;
}
