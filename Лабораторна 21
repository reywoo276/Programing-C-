#include <iostream>
#include <string>

class FlightBooking {
public:
    FlightBooking(int id, int capacity, int reserved);

    bool addReservation(int n);
    bool cancelReservation(int n);
    void printStatus();

private:
    int id;
    int capacity;
    int reserved;
};

FlightBooking::FlightBooking(int id, int capacity, int reserved) {
    this->id = id;
    this->capacity = capacity;

    int maxReserved = capacity * 105 / 100;

    if (reserved < 0)
        this->reserved = 0;
    else if (reserved > maxReserved)
        this->reserved = maxReserved;
    else
        this->reserved = reserved;
}

bool FlightBooking::addReservation(int n) {
    int maxReserved = capacity * 105 / 100;

    if (reserved + n > maxReserved)
        return false;

    reserved += n;
    return true;
}

bool FlightBooking::cancelReservation(int n) {
    if (reserved - n < 0)
        return false;

    reserved -= n;
    return true;
}

void FlightBooking::printStatus() {
    int percentage = reserved * 100 / capacity;

    std::cout << "Flight " << id
              << " : " << reserved
              << "/" << capacity
              << " (" << percentage
              << "%) seats reserved" << std::endl;
}

int main() {
    int capacity, reserved;

    std::cin >> capacity;
    std::cin >> reserved;

    FlightBooking booking(1, capacity, reserved);

    std::string command;

    while (std::cin >> command) {
        if (command == "quit")
            break;

        int n;
        std::cin >> n;

        bool success = false;

        if (command == "add")
            success = booking.addReservation(n);
        else if (command == "cancel")
            success = booking.cancelReservation(n);

        if (!success)
            std::cout << "Cannot perform this operation" << std::endl;

        booking.printStatus();
    }

    return 0;
}
