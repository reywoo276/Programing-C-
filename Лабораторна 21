#include <iostream>
#include <string>

class FlightBooking {
public:
    FlightBooking() {
        id = 0;
        capacity = 0;
        reserved = 0;
    }

    FlightBooking(int id, int capacity, int reserved = 0) {
        this->id = id;
        this->capacity = capacity;

        int maxReserved = capacity * 105 / 100;

        if (reserved < 0)
            this->reserved = 0;
        else if (reserved > maxReserved)
            this->reserved = maxReserved;
        else
            this->reserved = reserved;
    }

    int getId() {
        return id;
    }

    bool addReservation(int n) {
        if (reserved + n > capacity * 105 / 100)
            return false;

        reserved += n;
        return true;
    }

    bool cancelReservation(int n) {
        if (reserved - n < 0)
            return false;

        reserved -= n;
        return true;
    }

    void printStatus() {
        std::cout << "Flight " << id
                  << " : " << reserved
                  << "/" << capacity
                  << " (" << reserved * 100 / capacity
                  << "%) seats reserved" << std::endl;
    }

private:
    int id;
    int capacity;
    int reserved;
};

int findFlight(FlightBooking flights[], int id) {
    for (int i = 0; i < 10; i++) {
        if (flights[i].getId() == id)
            return i;
    }
    return -1;
}

int main() {
    FlightBooking flights[10];

    std::string command;

    while (std::cin >> command) {

        if (command == "quit")
            break;

        if (command == "create") {
            int id, cap;
            std::cin >> id >> cap;

            if (id == 0 || findFlight(flights, id) != -1) {
                std::cout << "Cannot perform this operation" << std::endl;
                continue;
            }

            bool created = false;

            for (int i = 0; i < 10; i++) {
                if (flights[i].getId() == 0) {
                    flights[i] = FlightBooking(id, cap, 0);
                    flights[i].printStatus();
                    created = true;
                    break;
                }
            }

            if (!created)
                std::cout << "Cannot perform this operation" << std::endl;
        }

        else if (command == "delete") {
            int id;
            std::cin >> id;

            int pos = findFlight(flights, id);

            if (pos == -1) {
                std::cout << "Cannot perform this operation" << std::endl;
                continue;
            }

            flights[pos] = FlightBooking();
        }

        else if (command == "add") {
            int id, n;
            std::cin >> id >> n;

            int pos = findFlight(flights, id);

            if (pos == -1 || !flights[pos].addReservation(n))
                std::cout << "Cannot perform this operation" << std::endl;
            else
                flights[pos].printStatus();
        }

        else if (command == "cancel") {
            int id, n;
            std::cin >> id >> n;

            int pos = findFlight(flights, id);

            if (pos == -1 || !flights[pos].cancelReservation(n))
                std::cout << "Cannot perform this operation" << std::endl;
            else
                flights[pos].printStatus();
        }
    }

    return 0;
}
