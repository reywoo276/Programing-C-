#include <iostream>
#include <ctime>
using namespace std;

struct Date {
    int year;
    int month;
    int day;
};

bool isLeap(int year) {
    if (year % 4 != 0)
        return false;
    else if (year % 100 != 0)
        return true;
    else if (year % 400 != 0)
        return false;
    else
        return true;
}

int monthLength(int year, int month) {
    int days[] = {31,28,31,30,31,30,31,31,30,31,30,31};

    if (month == 2 && isLeap(year))
        return 29;

    return days[month - 1];
}

Date today(void) {
    time_t t = time(NULL);
    tm tl = *localtime(&t);

    Date d;
    d.year = tl.tm_year + 1900;
    d.month = tl.tm_mon + 1;
    d.day = tl.tm_mday;

    return d;
}

int daysBetween(Date d1, Date d2) {
    int days = 0;

    while (!(d1.year == d2.year && d1.month == d2.month && d1.day == d2.day)) {
        d1.day++;
        days++;

        if (d1.day > monthLength(d1.year, d1.month)) {
            d1.day = 1;
            d1.month++;

            if (d1.month > 12) {
                d1.month = 1;
                d1.year++;
            }
        }
    }

    return days;
}

int main(void) {
    Date birth;

    cout << "Enter your birth date (year month day): ";
    cin >> birth.year >> birth.month >> birth.day;

    Date t = today();

    cout << "Current date: "
         << t.year << "-" << t.month << "-" << t.day << endl;

    int result = daysBetween(birth, t);

    cout << "Number of days since birth: " << result << endl;

    return 0;
}
