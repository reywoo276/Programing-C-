#include <iostream>
#include <string>
#include <sstream>

using namespace std;

class IPAddress {
protected:
    string ip;

public:
    IPAddress(string ip) {
        this->ip = ip;
    }

    IPAddress(const IPAddress& other) {
        ip = other.ip;
    }

    virtual void print() {
        cout << ip;
    }
};

class IPAddressChecked : public IPAddress {
private:
    bool correct;

    bool validate() {
        stringstream ss(ip);
        string part;
        int count = 0;

        while (getline(ss, part, '.')) {
            count++;

            if (part.empty())
                return false;

            int num = stoi(part);

            if (num < 0 || num > 255)
                return false;
        }

        return count == 4;
    }

public:
    IPAddressChecked(string ip) : IPAddress(ip) {
        correct = validate();
    }

    IPAddressChecked(const IPAddressChecked& other)
        : IPAddress(other) {
        correct = other.correct;
    }

    void print() override {
        IPAddress::print();

        if (correct)
            cout << " - Correct";
        else
            cout << " - Not Correct";
    }
};

int main() {
    string ip1, ip2, ip3;

    getline(cin, ip1);
    getline(cin, ip2);
    getline(cin, ip3);

    IPAddress obj1(ip1);
    IPAddressChecked obj2(ip2);
    IPAddressChecked obj3(ip3);

    obj1.print();
    cout << endl;

    obj2.print();
    cout << endl;

    obj3.print();
    cout << endl;

    return 0;
}
