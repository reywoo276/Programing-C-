#include <iostream>
#include <cmath>
using namespace std;

bool isPrime(int num) {
    if (num <= 1) return false;

    for (int i = 2; i * i <= num; i++) {
        if (num % i == 0)
            return false;
    }

    return true;
}

int main() {
    int n;
    cout << "Enter number: ";
    cin >> n;

    if (isPrime(n))
        cout << "Prime" << endl;
    else
        cout << "Not prime" << endl;

    return 0;
}
