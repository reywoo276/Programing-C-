#include <iostream>
#include <string>
#include <map>

using namespace std;

int main() {
    string values;
    getline(cin, values);

    string text;
    getline(cin, text);

    map<string, string> data;

    size_t start = 0;

    while (start < values.size()) {
        size_t comma = values.find(',', start);

        string pair;
        if (comma == string::npos)
            pair = values.substr(start);
        else
            pair = values.substr(start, comma - start);

        size_t eq = pair.find('=');

        if (eq != string::npos) {
            string key = pair.substr(0, eq);
            string value = pair.substr(eq + 1);
            data[key] = value;
        }

        if (comma == string::npos)
            break;

        start = comma + 1;
    }

    string result;
    size_t pos = 0;

    while (pos < text.size()) {
        if (text[pos] == '[') {
            size_t end = text.find(']', pos);

            if (end != string::npos) {
                string key = text.substr(pos + 1, end - pos - 1);

                if (data.count(key))
                    result += data[key];
                else
                    result += "[" + key + "]";

                pos = end + 1;
            } else {
                result += text[pos];
                pos++;
            }
        } else {
            result += text[pos];
            pos++;
        }
    }

    cout << result << endl;

    return 0;
}
